{
  "Logging": {
    "LogLevel": {
      "Default": "Warning"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "SingleLine": true,
        "TimestampFormat": "HH:mm:ss "
      }
    },
    "OpenTelemetry": {
      "IncludeFormattedMessage": true,
      "IncludeScopes": true,
      "ParseStateValues": true
    }
  },
  "notes": "OTEL_EXPORTER_OTLP_ENDPOINT is JetBrains Rider's built-in OTLP collector (Monitoring tool window); point it at your own collector if you're not running under Rider.",
  "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc",
  "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:17011",
  "OTEL_RESOURCE_ATTRIBUTES": "service.name=wolverine-salesforcepubsub-testhost,deployment.environment=dev,service.instance.id=localhost"
}
