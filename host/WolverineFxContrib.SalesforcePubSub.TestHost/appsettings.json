{
  "Logging": {
    "LogLevel": {      
      "Wolverine": "Debug",
      "Wolverine.SalesforcePubSub": "Trace",
      "Microsoft.Hosting.Lifetime": "Information"      
    }
  },
  "salesforceSettings": {
    "baseUri": "https://your-org.sandbox.my.salesforce.com/services/data/v64.0/",
    "pubSubUri": "https://api.pubsub.salesforce.com:7443",
    "subscriptions": [
      {
        "type": "Topic",
        "channel": "/event/CM_Test_Event_Two__e",
        "messageType": "TestEventTwo",
        "enabled": true
      },
      {
        "type": "ManagedSubscription",
        "channel": "CM_Test_Event_One",
        "messageType": "TestEventOne",
        "enabled": false
      }
    ]
  },
  "publisherSettings": {
    "enabled": false,
    "intervalSeconds": 15,
    "events": [ "CM_Test_Event_Two__e" ]
  },
  "salesforceReplaySettings": {
    "connectionString": "Server=your-sql-server.database.windows.net;Initial Catalog=CM_SalesforceReplayIdTest;Encrypt=True;Authentication=Active Directory Default",
    "application": "wolverine-salesforcepubsub-testhost",
    "instance": "wolverine-testhost"
  }
}
