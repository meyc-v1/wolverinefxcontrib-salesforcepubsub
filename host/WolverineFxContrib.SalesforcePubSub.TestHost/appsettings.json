{
  "Logging": {
    "LogLevel": {
      "Wolverine": "Information",
      "Wolverine.SalesforcePubSub": "Debug",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "salesforceSettings": {
    "notes": "baseUri set in user secrets",
    "pubSubUri": "https://api.pubsub.salesforce.com:7443",
    "subscriptions": [
      {
        "type": "Topic",
        "channel": "/event/CM_Test_Event_Two__e",
        "events": [
          { "messageType": "TestEventTwo", "eventApiName": "CM_Test_Event_Two__e" }
        ],
        "enabled": true
      },
      {
        "type": "ManagedSubscription",
        "channel": "CM_Test_Event_One",
        "events": [
          { "messageType": "TestEventOne", "eventApiName": "CM_Test_Event_One__e" }
        ],
        "enabled": true
      },
      {
        "type": "Topic",
        "channel": "/event/CM_Test_Channel__chn",
        "events": [
          { "messageType": "TestEventOne", "eventApiName": "CM_Test_Event_One__e" },
          { "messageType": "TestEventTwo", "eventApiName": "CM_Test_Event_Two__e" }
        ],
        "enabled": true
      },
      {
        "type": "ManagedSubscription",
        "channel": "CM_Test_Channel_Sub",
        "events": [
          { "messageType": "TestEventOne", "eventApiName": "CM_Test_Event_One__e" },
          { "messageType": "TestEventTwo", "eventApiName": "CM_Test_Event_Two__e" }
        ],
        "enabled": false
      }
    ]
  },
  "publisherSettings": {
    "enabled": false,
    "intervalSeconds": 300,
    "events": [ "CM_Test_Event_One__e", "CM_Test_Event_Two__e" ]
  },
  "heartbeat": {
    "enabled": true
  },
  "salesforceReplaySettings": {
    "notes": "connectionString set in user secrets",
    "application": "wolverine-salesforcepubsub-testhost",
    "instance": "wolverine-testhost"
  }
}
