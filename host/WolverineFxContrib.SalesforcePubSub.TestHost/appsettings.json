{
  "Logging": {
    "LogLevel": {      
      "Wolverine": "Debug",
      "Wolverine.SalesforcePubSub": "Trace",
      "Microsoft.Hosting.Lifetime": "Information"      
    }
  },
  "salesforceSettings": {
    "notes": "baseUri set in user secrets",
    "pubSubUri": "https://api.pubsub.salesforce.com:7443",
    "subscriptions": [
      {
        "type": "Topic",
        "channel": "/event/CM_Test_Event_Two__e",
        "messageType": "TestEventTwo",
        "enabled": true
      },
      {
        "type": "ManagedSubscription",
        "channel": "CM_Test_Event_One",
        "messageType": "TestEventOne",
        "enabled": true
      }
    ]
  },
  "publisherSettings": {
    "enabled": false,
    "intervalSeconds": 15,
    "events": [ "CM_Test_Event_One__e", "CM_Test_Event_Two__e" ]
  },
  "heartbeat": {
    "enabled": true
  },
  "salesforceReplaySettings": {
    "notes": "connectionString set in user secrets",
    "application": "wolverine-salesforcepubsub-testhost",
    "instance": "wolverine-testhost"
  }
}
